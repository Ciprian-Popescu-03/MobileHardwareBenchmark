<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Press 'Run' to start benchmarks."
            android:textSize="16sp"
            android:paddingBottom="16dp"/>

        <Button
            android:id="@+id/btn_run"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run Benchmark"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tv_header_bars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Graphs 1 &amp; 2: Performance Scores (Points)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <com.example.performancetester.SimpleBarChart
            android:id="@+id/bar_chart"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#F0F0F0"
            android:visibility="gone"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tv_header_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Graph 3: Sustained Performance (Stability %)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <com.example.performancetester.SimpleLineChart
            android:id="@+id/line_chart"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#F5F5F5"
            android:visibility="gone"/>

        <android.opengl.GLSurfaceView
            android:id="@+id/gl_view"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>